<launch>
  <!-- ============================================================ -->
  <!-- Inclined Corridor Test Environment (30 degrees downward slope) -->
  <!-- 倾斜走廊测试环境 - 测试局部坐标系在Z轴大范围变化场景的表现 -->
  <!-- ============================================================ -->
  
  <!-- Map size: 40x6x30 meters to accommodate the 30-degree slope -->
  <!-- 走廊从 z=25 (顶端) 下降到 z≈2 (底端)，总高度差约23米 -->
  <arg name="map_size_x" value="40.0"/>
  <arg name="map_size_y" value="6.0"/>
  <arg name="map_size_z" value="30.0"/>

  <!-- topic of your odometry such as VIO or LIO -->
  <arg name="odom_topic" value="/visual_slam/odom" />

  <!-- main algorithm params -->
  <include file="$(find ego_planner)/launch/advanced_param.xml">

    <arg name="map_size_x_" value="$(arg map_size_x)"/>
    <arg name="map_size_y_" value="$(arg map_size_y)"/>
    <arg name="map_size_z_" value="$(arg map_size_z)"/>
    <arg name="odometry_topic" value="$(arg odom_topic)"/>

    <!-- camera pose: transform of camera frame in the world frame -->
    <arg name="camera_pose_topic" value="/pcl_render_node/camera_pose"/>
    <arg name="depth_topic" value="/pcl_render_node/depth"/>
    <arg name="cloud_topic" value="/pcl_render_node/cloud"/>

    <!-- intrinsic params of the depth camera -->
    <arg name="cx" value="321.04638671875"/>
    <arg name="cy" value="243.44969177246094"/>
    <arg name="fx" value="387.229248046875"/>
    <arg name="fy" value="387.229248046875"/>

    <!-- maximum velocity and acceleration -->
    <!-- 下坡时适当降低速度以确保安全 -->
    <arg name="max_vel" value="1.5" />
    <arg name="max_acc" value="2.0" />

    <!-- planning horizon -->
    <arg name="planning_horizon" value="7.5" /> 

    <!-- 2: use global waypoints (automatic mode) -->
    <arg name="flight_type" value="2" />
    
    <!-- ========== 关键参数：扩展高度限制以适应倾斜走廊 ========== -->
    <!-- ground_height: 走廊底部最低点，留有余量 -->
    <arg name="ground_height" value="0.0"/>
    <!-- virtual_ceil_height: 走廊顶部最高点，留有余量 -->
    <arg name="virtual_ceil_height" value="30.0"/>
    <!-- local_frame_map_size_z: 局部坐标系Z轴范围，需覆盖走廊截面高度 -->
    <arg name="local_frame_map_size_z" value="15.0"/>
    
    <!-- ========== 航点配置 ========== -->
    <!-- 30度坡：tan(30°) ≈ 0.577，每前进1m下降0.577m -->
    <!-- 走廊地板公式: z = 25 - 0.577 * (x + 20) -->
    <!-- 无人机飞行在地板上方约2米处 -->
    <arg name="point_num" value="4" />

    <!-- Waypoint 0: 起始下降段 (x=-10, 地板z≈19.2, 飞行z≈21) -->
    <arg name="point0_x" value="-10.0" />
    <arg name="point0_y" value="1.0" />
    <arg name="point0_z" value="21.0" />

    <!-- Waypoint 1: 走廊中段 (x=0, 地板z≈13.5, 飞行z≈15.5) -->
    <arg name="point1_x" value="0.0" />
    <arg name="point1_y" value="-1.0" />
    <arg name="point1_z" value="15.5" />

    <!-- Waypoint 2: 下段 (x=10, 地板z≈7.7, 飞行z≈9.5) -->
    <arg name="point2_x" value="10.0" />
    <arg name="point2_y" value="1.0" />
    <arg name="point2_z" value="9.5" />

    <!-- Waypoint 3: 走廊底端 (x=18, 地板z≈3.1, 飞行z≈5) -->
    <arg name="point3_x" value="18.0" />
    <arg name="point3_y" value="0.0" />
    <arg name="point3_z" value="5.0" />
    
  </include>

  <!-- trajectory server -->
  <node pkg="ego_planner" name="traj_server" type="traj_server" output="screen">
    <remap from="/position_cmd" to="planning/pos_cmd"/>
    <remap from="/odom_world" to="$(arg odom_topic)"/>
    <param name="traj_server/time_forward" value="1.0" type="double"/>
  </node>

  <node pkg="waypoint_generator" name="waypoint_generator" type="waypoint_generator" output="screen">
    <remap from="~odom" to="$(arg odom_topic)"/>        
    <remap from="~goal" to="/move_base_simple/goal"/>
    <remap from="~traj_start_trigger" to="/traj_start_trigger" />
    <param name="waypoint_type" value="manual-lonely-waypoint"/>    
  </node>

  <!-- use simulator with inclined corridor map -->
  <include file="$(find ego_planner)/launch/simulator.xml">
    <arg name="map_size_x_" value="$(arg map_size_x)"/>
    <arg name="map_size_y_" value="$(arg map_size_y)"/>
    <arg name="map_size_z_" value="$(arg map_size_z)"/>
    
    <!-- 使用倾斜走廊地图类型 -->
    <arg name="map_type" value="inclined_corridor"/>
    
    <!-- 增加传感器探测距离以适应大高度差环境 (默认5.0m不足) -->
    <arg name="sensing_horizon" value="15.0"/>
    
    <!-- 无人机起始位置：走廊顶端入口，地板z=25，飞行高度z≈27 -->
    <arg name="init_x" value="-18.0"/>
    <arg name="init_y" value="0.0"/>
    <arg name="init_z" value="27.0"/>
    
    <!-- 障碍物由地图生成器固定生成，这里设为0 -->
    <arg name="c_num" value="0"/>
    <arg name="p_num" value="0"/>
    <arg name="min_dist" value="2.0"/>

    <arg name="odometry_topic" value="$(arg odom_topic)" />
  </include>

  <include file="$(find ego_planner)/launch/rviz.launch"/>

</launch>
