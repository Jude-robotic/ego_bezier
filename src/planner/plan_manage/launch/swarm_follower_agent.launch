<launch>
    <arg name="ns" default="uav1"/>
    <arg name="agent_id" default="1"/>

    <arg name="init_x" default="-2.0"/>
    <arg name="init_y" default="-2.0"/>
    <arg name="init_z" default="1.0"/>

    <arg name="guidance_topic" default="/swarm/agent_1/guidance_bezier"/>
    <arg name="state_topic" default="/swarm/agent_1/state"/>
    <arg name="guidance_min_start_time_delay" default="0.005"/>
    <arg name="startup_hold_enabled" default="true"/>
    <arg name="startup_guidance_ready_frames" default="5"/>
    <arg name="startup_guidance_soft_ready_frames" default="2"/>
    <arg name="startup_guidance_soft_lock_timeout" default="0.45"/>
    <arg name="startup_bridge_duration" default="0.75"/>
    <arg name="startup_hover_timeout" default="0.40"/>
    <arg name="startup_warmup_frames" default="15"/>
    <arg name="startup_nominal_guidance_rate" default="20.0"/>
    <arg name="startup_bridge_stitch_pos_margin" default="0.15"/>
    <arg name="startup_bridge_max_stitch_speed" default="0.25"/>
    <arg name="startup_bridge_use_s_curve_alpha" default="true"/>
    <arg name="startup_anchor_pos_filter_alpha" default="0.35"/>
    <arg name="startup_anchor_vel_filter_alpha" default="0.25"/>
    <arg name="startup_guidance_ready_speed_tol" default="0.35"/>
    <arg name="startup_guidance_ready_dir_tol_deg" default="18.0"/>
    <arg name="startup_guidance_ready_max_acc" default="3.0"/>
    <arg name="startup_guidance_ready_max_turn_deg" default="40.0"/>
    <arg name="startup_bridge_ctrl_points" default="7"/>
    <arg name="startup_bridge_blend_power" default="1.6"/>
    <arg name="startup_bridge_anchor_max_speed" default="0.25"/>
    <arg name="startup_bridge_head_max_turn_deg" default="25.0"/>
    <arg name="startup_bridge_head_max_speed" default="0.8"/>
    <arg name="startup_bridge_head_max_acc" default="2.0"/>
    <arg name="startup_bridge_p2_pos_margin" default="0.18"/>
    <arg name="state_timeout" default="0.2"/>

    <!-- Visualization color only.
      IMPORTANT: This does NOT change dynamics/control; follower physics stays aligned with leader. -->
    <arg name="viz_color_r" default="0.0"/>
    <arg name="viz_color_g" default="0.0"/>
    <arg name="viz_color_b" default="1.0"/>
    <arg name="viz_color_a" default="1.0"/>

    <!-- Local map / sensing profile -->
    <arg name="use_local_map" default="false"/>
    <arg name="use_real_data" default="false"/>

    <!-- Sim sensing topics -->
    <arg name="sim_odom_topic" default="odom"/>
    <arg name="sim_cloud_topic" default="/map_generator/global_cloud"/>

    <!-- Real sensing topics (template) -->
    <arg name="real_odom_topic" default="/mocap/odom"/>
    <arg name="real_cloud_topic" default="/lidar/points"/>
    <arg name="real_depth_topic" default="/camera/depth/image_rect_raw"/>
    <arg name="real_pose_topic" default="/camera/pose"/>
    <arg name="require_preflight_ok" default="false"/>

    <group ns="$(arg ns)">
      <node pkg="so3_quadrotor_simulator" type="quadrotor_simulator_so3" name="quadrotor_simulator_so3" output="screen">
        <param name="rate/odom" value="200.0"/>
        <param name="simulator/init_state_x" value="$(arg init_x)"/>
        <param name="simulator/init_state_y" value="$(arg init_y)"/>
        <param name="simulator/init_state_z" value="$(arg init_z)"/>

        <remap from="~odom" to="odom"/>
        <remap from="~cmd" to="so3_cmd"/>
        <remap from="~force_disturbance" to="force_disturbance"/>
        <remap from="~moment_disturbance" to="moment_disturbance"/>
      </node>

      <node pkg="nodelet" type="nodelet" args="standalone so3_control/SO3ControlNodelet" name="so3_control" required="false" respawn="true" respawn_delay="1.0" output="screen">
        <param name="so3_control/init_state_x" value="$(arg init_x)"/>
        <param name="so3_control/init_state_y" value="$(arg init_y)"/>
        <param name="so3_control/init_state_z" value="$(arg init_z)"/>

        <remap from="~odom" to="odom"/>
        <remap from="~position_cmd" to="planning/pos_cmd"/>
        <remap from="~motors" to="motors"/>
        <remap from="~corrections" to="corrections"/>
        <remap from="~so3_cmd" to="so3_cmd"/>

        <rosparam file="$(find so3_control)/config/gains_hummingbird.yaml"/>
        <rosparam file="$(find so3_control)/config/corrections_hummingbird.yaml"/>
        <param name="mass" value="0.98"/>
        <param name="use_angle_corrections " value="false"/>
        <param name="use_external_yaw " value="false"/>
        <param name="gains/rot/z" value="1.0"/>
        <param name="gains/ang/z" value="0.1"/>
      </node>

      <group unless="$(arg use_local_map)">
        <node pkg="ego_planner" type="swarm_follower_guidance_optimizer_node" name="swarm_follower_guidance_optimizer" output="screen">
          <param name="enable_local_refine" value="false"/>
          <param name="enable_collision_rebound" value="false"/>
          <param name="use_local_map" value="false"/>
          <param name="min_start_time_delay" value="$(arg guidance_min_start_time_delay)"/>
          <param name="fallback_segment_dt" value="0.1"/>
          <param name="stitch_time_margin"   value="0.12"/>
          <param name="refine_window_segs"   value="5"/>
          <param name="startup_hold_enabled" value="$(arg startup_hold_enabled)"/>
          <param name="startup_guidance_ready_frames" value="$(arg startup_guidance_ready_frames)"/>
          <param name="startup_guidance_soft_ready_frames" value="$(arg startup_guidance_soft_ready_frames)"/>
          <param name="startup_guidance_soft_lock_timeout" value="$(arg startup_guidance_soft_lock_timeout)"/>
          <param name="startup_bridge_duration" value="$(arg startup_bridge_duration)"/>
          <param name="startup_hover_timeout" value="$(arg startup_hover_timeout)"/>
          <param name="warmup_frames" value="$(arg startup_warmup_frames)"/>
          <param name="startup_nominal_guidance_rate" value="$(arg startup_nominal_guidance_rate)"/>
          <param name="startup_bridge_stitch_pos_margin" value="$(arg startup_bridge_stitch_pos_margin)"/>
          <param name="startup_bridge_max_stitch_speed" value="$(arg startup_bridge_max_stitch_speed)"/>
          <param name="startup_bridge_use_s_curve_alpha" value="$(arg startup_bridge_use_s_curve_alpha)"/>
          <param name="startup_anchor_pos_filter_alpha" value="$(arg startup_anchor_pos_filter_alpha)"/>
          <param name="startup_anchor_vel_filter_alpha" value="$(arg startup_anchor_vel_filter_alpha)"/>
          <param name="startup_guidance_ready_speed_tol" value="$(arg startup_guidance_ready_speed_tol)"/>
          <param name="startup_guidance_ready_dir_tol_deg" value="$(arg startup_guidance_ready_dir_tol_deg)"/>
          <param name="startup_guidance_ready_max_acc" value="$(arg startup_guidance_ready_max_acc)"/>
          <param name="startup_guidance_ready_max_turn_deg" value="$(arg startup_guidance_ready_max_turn_deg)"/>
          <param name="startup_bridge_ctrl_points" value="$(arg startup_bridge_ctrl_points)"/>
          <param name="startup_bridge_blend_power" value="$(arg startup_bridge_blend_power)"/>
          <param name="startup_bridge_anchor_max_speed" value="$(arg startup_bridge_anchor_max_speed)"/>
          <param name="startup_bridge_head_max_turn_deg" value="$(arg startup_bridge_head_max_turn_deg)"/>
          <param name="startup_bridge_head_max_speed" value="$(arg startup_bridge_head_max_speed)"/>
          <param name="startup_bridge_head_max_acc" value="$(arg startup_bridge_head_max_acc)"/>
          <param name="startup_bridge_p2_pos_margin" value="$(arg startup_bridge_p2_pos_margin)"/>

          <param name="optimization/lambda_smooth" value="0.5"/>
          <param name="optimization/lambda_collision" value="5.0"/>
          <param name="optimization/lambda_feasibility" value="2.0"/>
          <!-- lambda_fitness(lambda4): 主机默认值为 1.0，此处设为 2.0（2×）。
               增强从机局部优化时对 master 引导轨迹的回归拉力，
               避障绕行后能更快收敛回编队轨迹，避免持续发散。
               enable_collision_rebound=false / use_local_map=false 时
               lambda_fitness 是唯一的轨迹形状约束，提权效果最直接。 -->
          <param name="optimization/lambda_fitness" value="2.0"/>
          <param name="optimization/dist0" value="0.5"/>
          <param name="optimization/max_vel" value="2.0"/>
          <param name="optimization/max_acc" value="3.0"/>
          <param name="optimization/order" value="3"/>

          <remap from="~guidance_in" to="$(arg guidance_topic)"/>
          <remap from="~planning/bezier" to="planning/bezier"/>
          <!-- 始终提供 odom（用于首次 guidance p_stitch 修正和 warmup 过渡）-->
          <remap from="~odom_in" to="$(arg sim_odom_topic)"/>
        </node>
      </group>

      <group if="$(arg use_local_map)">
        <group unless="$(arg use_real_data)">
            <node pkg="ego_planner" type="swarm_follower_guidance_optimizer_node" name="swarm_follower_guidance_optimizer" output="screen">
              <!-- rosparam 必须在 node 内加载，确保参数落在节点私有命名空间 ~ -->
              <!-- 否则 GridMap 通过私有 NodeHandle 查找参数时会找不到 -->
              <rosparam file="$(find ego_planner)/launch/swarm_follower_local_map_sim.yaml" command="load"/>

              <param name="enable_local_refine" value="true"/>
              <param name="enable_collision_rebound" value="true"/>
              <param name="use_local_map" value="true"/>
              <param name="min_start_time_delay" value="$(arg guidance_min_start_time_delay)"/>
              <param name="fallback_segment_dt" value="0.1"/>
              <param name="stitch_time_margin"   value="0.12"/>
              <param name="refine_window_segs"   value="5"/>
              <param name="startup_hold_enabled" value="$(arg startup_hold_enabled)"/>
              <param name="startup_guidance_ready_frames" value="$(arg startup_guidance_ready_frames)"/>
              <param name="startup_guidance_soft_ready_frames" value="$(arg startup_guidance_soft_ready_frames)"/>
              <param name="startup_guidance_soft_lock_timeout" value="$(arg startup_guidance_soft_lock_timeout)"/>
              <param name="startup_bridge_duration" value="$(arg startup_bridge_duration)"/>
              <param name="startup_hover_timeout" value="$(arg startup_hover_timeout)"/>
              <param name="warmup_frames" value="$(arg startup_warmup_frames)"/>
              <param name="startup_nominal_guidance_rate" value="$(arg startup_nominal_guidance_rate)"/>
              <param name="startup_bridge_stitch_pos_margin" value="$(arg startup_bridge_stitch_pos_margin)"/>
              <param name="startup_bridge_max_stitch_speed" value="$(arg startup_bridge_max_stitch_speed)"/>
              <param name="startup_bridge_use_s_curve_alpha" value="$(arg startup_bridge_use_s_curve_alpha)"/>
              <param name="startup_anchor_pos_filter_alpha" value="$(arg startup_anchor_pos_filter_alpha)"/>
              <param name="startup_anchor_vel_filter_alpha" value="$(arg startup_anchor_vel_filter_alpha)"/>
              <param name="startup_guidance_ready_speed_tol" value="$(arg startup_guidance_ready_speed_tol)"/>
              <param name="startup_guidance_ready_dir_tol_deg" value="$(arg startup_guidance_ready_dir_tol_deg)"/>
              <param name="startup_guidance_ready_max_acc" value="$(arg startup_guidance_ready_max_acc)"/>
              <param name="startup_guidance_ready_max_turn_deg" value="$(arg startup_guidance_ready_max_turn_deg)"/>
              <param name="startup_bridge_ctrl_points" value="$(arg startup_bridge_ctrl_points)"/>
              <param name="startup_bridge_blend_power" value="$(arg startup_bridge_blend_power)"/>
              <param name="startup_bridge_anchor_max_speed" value="$(arg startup_bridge_anchor_max_speed)"/>
              <param name="startup_bridge_head_max_turn_deg" value="$(arg startup_bridge_head_max_turn_deg)"/>
              <param name="startup_bridge_head_max_speed" value="$(arg startup_bridge_head_max_speed)"/>
              <param name="startup_bridge_head_max_acc" value="$(arg startup_bridge_head_max_acc)"/>
              <param name="startup_bridge_p2_pos_margin" value="$(arg startup_bridge_p2_pos_margin)"/>

              <param name="optimization/lambda_smooth" value="0.5"/>
              <param name="optimization/lambda_collision" value="5.0"/>
              <param name="optimization/lambda_feasibility" value="2.0"/>
              <!-- lambda_fitness: 3.0，引导轨迹回归拉力（Rebound 后 Refine 用）-->
              <param name="optimization/lambda_fitness" value="3.0"/>
              <param name="optimization/dist0" value="0.5"/>
              <param name="optimization/max_vel" value="2.0"/>
              <param name="optimization/max_acc" value="3.0"/>
              <param name="optimization/order" value="3"/>

              <!-- 被动避障参数 -->
              <param name="safety_look_ahead"  value="2.0"/>
              <param name="safety_check_step"  value="0.05"/>
              <param name="safety_cooldown"    value="0.25"/>

              <!-- 关键 remap：引导话题与规划输出（原先缺失，导致节点完全不工作）-->
              <remap from="~guidance_in" to="$(arg guidance_topic)"/>
              <remap from="~planning/bezier" to="planning/bezier"/>

              <!-- GridMap 话题：全局点云 + 从机自身 odom -->
              <remap from="/grid_map/odom" to="$(arg sim_odom_topic)"/>
              <remap from="/grid_map/cloud" to="$(arg sim_cloud_topic)"/>

              <!-- 被动避障 odom -->
              <remap from="~odom_in" to="$(arg sim_odom_topic)"/>
            </node>
          </group>

        <group if="$(arg use_real_data)">
            <node pkg="ego_planner" type="swarm_follower_guidance_optimizer_node" name="swarm_follower_guidance_optimizer" output="screen">
              <!-- rosparam 必须在 node 内加载，确保参数落在节点私有命名空间 ~ -->
              <rosparam file="$(find ego_planner)/launch/swarm_follower_local_map_real.yaml" command="load"/>
            <param name="enable_local_refine" value="true"/>
            <param name="enable_collision_rebound" value="true"/>
            <param name="use_local_map" value="true"/>
            <param name="min_start_time_delay" value="$(arg guidance_min_start_time_delay)"/>
            <param name="fallback_segment_dt" value="0.1"/>
            <param name="stitch_time_margin"   value="0.12"/>
            <param name="refine_window_segs"   value="5"/>
            <param name="startup_hold_enabled" value="$(arg startup_hold_enabled)"/>
            <param name="startup_guidance_ready_frames" value="$(arg startup_guidance_ready_frames)"/>
            <param name="startup_guidance_soft_ready_frames" value="$(arg startup_guidance_soft_ready_frames)"/>
            <param name="startup_guidance_soft_lock_timeout" value="$(arg startup_guidance_soft_lock_timeout)"/>
            <param name="startup_bridge_duration" value="$(arg startup_bridge_duration)"/>
            <param name="startup_hover_timeout" value="$(arg startup_hover_timeout)"/>
            <param name="warmup_frames" value="$(arg startup_warmup_frames)"/>
            <param name="startup_nominal_guidance_rate" value="$(arg startup_nominal_guidance_rate)"/>
            <param name="startup_bridge_stitch_pos_margin" value="$(arg startup_bridge_stitch_pos_margin)"/>
            <param name="startup_bridge_max_stitch_speed" value="$(arg startup_bridge_max_stitch_speed)"/>
            <param name="startup_bridge_use_s_curve_alpha" value="$(arg startup_bridge_use_s_curve_alpha)"/>
            <param name="startup_anchor_pos_filter_alpha" value="$(arg startup_anchor_pos_filter_alpha)"/>
            <param name="startup_anchor_vel_filter_alpha" value="$(arg startup_anchor_vel_filter_alpha)"/>
            <param name="startup_guidance_ready_speed_tol" value="$(arg startup_guidance_ready_speed_tol)"/>
            <param name="startup_guidance_ready_dir_tol_deg" value="$(arg startup_guidance_ready_dir_tol_deg)"/>
            <param name="startup_guidance_ready_max_acc" value="$(arg startup_guidance_ready_max_acc)"/>
            <param name="startup_guidance_ready_max_turn_deg" value="$(arg startup_guidance_ready_max_turn_deg)"/>
            <param name="startup_bridge_ctrl_points" value="$(arg startup_bridge_ctrl_points)"/>
            <param name="startup_bridge_blend_power" value="$(arg startup_bridge_blend_power)"/>
            <param name="startup_bridge_anchor_max_speed" value="$(arg startup_bridge_anchor_max_speed)"/>
            <param name="startup_bridge_head_max_turn_deg" value="$(arg startup_bridge_head_max_turn_deg)"/>
            <param name="startup_bridge_head_max_speed" value="$(arg startup_bridge_head_max_speed)"/>
            <param name="startup_bridge_head_max_acc" value="$(arg startup_bridge_head_max_acc)"/>
            <param name="startup_bridge_p2_pos_margin" value="$(arg startup_bridge_p2_pos_margin)"/>

            <param name="optimization/lambda_smooth" value="0.5"/>
            <param name="optimization/lambda_collision" value="5.0"/>
            <param name="optimization/lambda_feasibility" value="2.0"/>
            <!-- lambda_fitness: 提升至 3.0 增强收敛（被动避障 Refine 回归拉力） -->
            <param name="optimization/lambda_fitness" value="3.0"/>
            <param name="optimization/dist0" value="0.5"/>
            <param name="optimization/max_vel" value="2.0"/>
            <param name="optimization/max_acc" value="3.0"/>
            <param name="optimization/order" value="3"/>

            <!-- 被动避障参数 -->
            <param name="safety_look_ahead"  value="2.0"/>  <!-- 向前看 2 秒 -->
            <param name="safety_check_step"  value="0.05"/> <!-- 20Hz 采样 -->
            <param name="safety_cooldown"    value="0.25"/> <!-- 重规划冷却 0.25s -->

            <remap from="~guidance_in" to="$(arg guidance_topic)"/>
            <remap from="~planning/bezier" to="planning/bezier"/>
            <remap from="/grid_map/odom" to="$(arg real_odom_topic)"/>
            <remap from="/grid_map/cloud" to="$(arg real_cloud_topic)"/>
            <remap from="/grid_map/depth" to="$(arg real_depth_topic)"/>
            <remap from="/grid_map/pose" to="$(arg real_pose_topic)"/>

            <!-- odom remap（从机实机 odom 话题） -->
            <remap from="~odom_in" to="$(arg real_odom_topic)"/>
          </node>
        </group>
      </group>

      <node pkg="ego_planner" name="traj_server" type="traj_server" output="screen">
        <param name="require_preflight_ok" value="$(arg require_preflight_ok)"/>
        <param name="preflight_ok_topic" value="/swarm/preflight/ok"/>
        <remap from="/odom_world" to="odom"/>
        <remap from="/position_cmd" to="planning/pos_cmd"/>
      </node>

      <node pkg="ego_planner" type="swarm_agent_state_reporter_node" name="swarm_agent_state_reporter" output="screen">
        <param name="agent_id" value="$(arg agent_id)"/>
        <param name="publish_rate" value="30.0"/>
        <param name="state_timeout" value="$(arg state_timeout)"/>
        <remap from="~odom" to="odom"/>
        <remap from="~state_out" to="$(arg state_topic)"/>
      </node>

      <node pkg="odom_visualization" name="odom_visualization" type="odom_visualization" output="screen">
        <remap from="~odom" to="odom"/>
        <param name="color/a" value="$(arg viz_color_a)"/>
        <param name="color/r" value="$(arg viz_color_r)"/>
        <param name="color/g" value="$(arg viz_color_g)"/>
        <param name="color/b" value="$(arg viz_color_b)"/>
        <param name="covariance_scale" value="100.0"/>
        <param name="robot_scale" value="0.8"/>
        <param name="tf45" value="true"/>
      </node>
    </group>
  </launch>
